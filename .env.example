# Neo4j AuraDB
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password-here
NEO4J_DATABASE=neo4j
NEO4J_CONNECTION_TIMEOUT_SECONDS=5
NEO4J_CONNECTION_ACQUISITION_TIMEOUT_SECONDS=5
NEO4J_MAX_TRANSACTION_RETRY_SECONDS=10
NEO4J_QUERY_TIMEOUT_SECONDS=10

# Google Gemini (from aistudio.google.com → Get API key)
GOOGLE_API_KEY=your-google-ai-studio-api-key

# Google Cloud (optional — only needed if SANDBOX_MOCK=false)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Sandbox — UI sandbox runs are Cloud Run only.
SANDBOX_MOCK=false
SANDBOX_MODE=cloudrun
SANDBOX_GCP_REGION=us-central1
SANDBOX_JOB_NAME=ecolink-sandbox-executor
SANDBOX_INVOKER_SERVICE_ACCOUNT=sandbox-job-invoker@your-gcp-project-id.iam.gserviceaccount.com
SANDBOX_SOURCE_BUCKET=your-sandbox-source-bucket
SANDBOX_SOURCE_PATH=/absolute/path/to/project

# Capability tokens — production uses Cloud KMS RS256 signing.
CAPABILITY_TOKEN_AUDIENCE=ecolink-sandbox-job
CAPABILITY_TOKEN_TTL_SECONDS=600
CAPABILITY_KMS_KEY_VERSION=projects/your-gcp-project-id/locations/us-central1/keyRings/ecolink-sandbox/cryptoKeys/capability-jwt/cryptoKeyVersions/1
CAPABILITY_JWT_PUBLIC_KEY_PATH=/absolute/path/to/capability-jwt-public.pem
# Local tests only: use an RS256 private key when Cloud KMS is not available.
CAPABILITY_JWT_PRIVATE_KEY=
